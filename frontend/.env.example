# OSCA Frontend Environment Variables
# Copy this file to .env and update values for your deployment.

# Backend API URL — must point to your Laravel server (no trailing slash)
# Development:
VITE_API_URL=http://127.0.0.1:8000/api
# Production example:
# VITE_API_URL=https://osca.pagsanjan.gov.ph/api

# Gemini AI key (optional, for AI-powered features)
GEMINI_API_KEY=
